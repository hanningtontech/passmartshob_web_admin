# Backblaze B2 – S3-compatible API (use an Application Key, not Master Key)
B2_KEY_ID=your_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=passmartshop-media
# Optional; default us-west-004. Use your bucket's region (e.g. us-east-005).
B2_REGION=us-west-004
# Optional; public URL base for uploaded files (e.g. CDN or bucket URL).
# If unset, uses https://<bucket>.s3.<region>.backblazeb2.com
# B2_PUBLIC_URL_PREFIX=https://your-bucket.s3.us-west-004.backblazeb2.com
PORT=3001
